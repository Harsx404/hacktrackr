{
  "name": "hacktrackr",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "academia": "npm --prefix academia-backend run api",
    "academia:api": "npm --prefix academia-backend run api",
    "academia:faculty": "npm --prefix academia-backend run faculty",
    "dev:all": "academia-backend\\node_modules\\.bin\\concurrently --names \"EXPO,ACADEMIA\" --prefix-colors \"green,cyan\" \"npm start\" \"npm run academia\""
  },
  "dependencies": {
